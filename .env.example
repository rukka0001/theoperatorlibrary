# ─────────────────────────────────────────────────────────────
# TheOperatorLibrary.com — environment variables
# Copy this file to `.env` and fill in the values.
# Never commit `.env`. Keep all secrets here, never in source.
# ─────────────────────────────────────────────────────────────

# Public site URL (used to build absolute links in emails, redirects, etc.)
# PUBLIC_ vars are exposed to the client — do NOT put secrets here.
PUBLIC_SITE_URL=http://localhost:4321

# ── Flow payments (https://www.flow.cl) ──────────────────────
# Chilean payment gateway. Amounts are in CLP.
FLOW_API_KEY=
FLOW_SECRET_KEY=
# Production: https://www.flow.cl/api   Sandbox: https://sandbox.flow.cl/api
FLOW_API_URL=https://sandbox.flow.cl/api

# ── Resend (transactional email / file delivery) ─────────────
# https://resend.com
RESEND_API_KEY=
# Verified sender for transactional/delivery email. Must be a Resend-verified
# address, e.g. "TheOperatorLibrary <delivery@mail.theoperatorlibrary.com>".
RESEND_FROM_EMAIL=
# Optional overrides for the public-facing business emails. Defaults are baked
# into src/config/business.ts, so these are only needed to change the addresses
# without a code change. NOT secrets — they appear publicly on the site.
# Delivery replies + support/help links use SUPPORT_EMAIL; footer/privacy use
# CONTACT_EMAIL.
CONTACT_EMAIL=hello@theoperatorlibrary.com
SUPPORT_EMAIL=support@theoperatorlibrary.com
# Optional: internal recipient for the "Nueva venta" sale notification, sent
# AFTER the buyer's delivery email succeeds. Contains no download links/secrets.
# Leave blank to skip it — buyer delivery is never affected either way.
ORDER_NOTIFICATION_EMAIL=chris@theoperatorlibrary.com
# Optional: enables GET /api/test-email for manual Resend smoke tests.
# Leave blank to keep that route disabled (404). Generate with: openssl rand -hex 16
TEST_EMAIL_KEY=

# ── Vercel Blob (digital file storage) ───────────────────────
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# ── Signed download links (jose / JWT) ───────────────────────
# Long random string used to sign time-limited download tokens.
# Generate with: openssl rand -base64 32
DOWNLOAD_TOKEN_SECRET=
# How long a download link stays valid, in seconds (604800 = 7 days).
DOWNLOAD_TOKEN_TTL=604800

# Lemon Squeezy (English edition / USD)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
