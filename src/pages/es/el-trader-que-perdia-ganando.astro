---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProduct, formatCLP } from '../../config/products';

const product = getProduct('el-trader-que-perdia-ganando')!;
const discountPct = product.regularPriceCLP
  ? Math.round((1 - product.priceCLP / product.regularPriceCLP) * 100)
  : 0;

// Decorative candlestick data for the hero background (deterministic).
const candles = Array.from({ length: 36 }, (_, i) => {
  const x = i * 24 + 12;
  const mid = 150 + Math.sin(i * 0.55) * 55 - i * 1.2;
  const h = 16 + ((i * 37) % 46);
  const wick = 12 + ((i * 13) % 26);
  const up = (i * 7) % 3 !== 0;
  return { x, y: mid - h / 2, h, wick, up };
});

const faqs = [
  {
    q: '¿Es un curso?',
    a: 'No. Es un ebook práctico acompañado de hojas de referencia. Lo lees a tu ritmo y aplicas lo que necesites, sin clases ni plataformas.'
  },
  {
    q: '¿Incluye señales o alertas?',
    a: 'No. No vendemos señales, alertas ni una sala de trading. El objetivo es que entiendas tu propio proceso, no que dependas del de otra persona.'
  },
  {
    q: '¿Cómo recibo el ebook?',
    a: 'Después del pago recibes un correo con los botones de descarga de todos los archivos: PDF, EPUB, Kindle/AZW3 y las hojas de referencia.'
  },
  {
    q: '¿Sirve si estoy en Chile?',
    a: 'Sí. El pago se procesa de forma segura en Chile vía Flow, en pesos chilenos (CLP). El contenido aplica a cualquier trader de habla hispana.'
  },
  {
    q: '¿Es asesoramiento financiero?',
    a: 'No. El material es solo para fines educativos. No es asesoramiento financiero ni una recomendación de inversión. Las decisiones que tomes son tu responsabilidad.'
  },
  {
    q: '¿En qué formato viene?',
    a: 'El ebook viene en PDF, EPUB y Kindle/AZW3. Las hojas de referencia y la tarjeta de reglas vienen en PDF listas para imprimir o usar en pantalla.'
  }
];

const previews = [
  {
    title: 'Las cinco palabras que me costaron todo',
    teaser:
      'La frase que casi todo trader se repite justo antes de convertir una pérdida pequeña en una catástrofe.'
  },
  {
    title: 'El recibo',
    teaser:
      'Lo que de verdad pagas cada vez que rompes tus propias reglas — más allá del número en la pantalla.'
  },
  {
    title: 'La única matemática que importa',
    teaser:
      'Por qué tu porcentaje de aciertos puede mentirte y qué número deberías mirar en su lugar.'
  }
];

const buyHref = '#comprar';
---

<BaseLayout
  title={`${product.title} — The Operator Library`}
  description={product.subtitle}
>
  <article class="pb-24 lg:pb-0">
    <!-- ───────────── HERO ───────────── -->
    <section
      id="comprar"
      class="relative scroll-mt-24 overflow-hidden border-b border-stone-800/80"
    >
      <!-- Candlestick backdrop -->
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.18]"
        aria-hidden="true"
      >
        <svg
          class="h-full w-full"
          viewBox="0 0 840 300"
          preserveAspectRatio="xMidYMid slice"
        >
          <defs>
            <linearGradient id="fade" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#fff" stop-opacity="0.0" />
              <stop offset="0.5" stop-color="#fff" stop-opacity="1" />
              <stop offset="1" stop-color="#fff" stop-opacity="0.0" />
            </linearGradient>
            <mask id="fademask">
              <rect width="840" height="300" fill="url(#fade)" />
            </mask>
          </defs>
          <g mask="url(#fademask)" stroke-width="2">
            {
              candles.map((c) => {
                const color = c.up ? '#34d399' : '#f87171';
                return (
                  <g stroke={color} fill={color}>
                    <line
                      x1={c.x + 4}
                      y1={c.y - c.wick}
                      x2={c.x + 4}
                      y2={c.y + c.h + c.wick}
                    />
                    <rect
                      x={c.x}
                      y={c.y}
                      width="8"
                      height={c.h}
                      rx="1"
                      fill-opacity={c.up ? 0.55 : 0.4}
                    />
                  </g>
                );
              })
            }
          </g>
        </svg>
      </div>
      <!-- Radial glow -->
      <div
        class="pointer-events-none absolute -top-32 left-1/2 h-72 w-[42rem] -translate-x-1/2 rounded-full bg-amber-400/10 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="relative mx-auto max-w-6xl px-6 py-16 sm:py-20 lg:py-24">
        <div class="grid items-center gap-14 lg:grid-cols-[minmax(0,1fr)_24rem]">
          <!-- Hero copy -->
          <div>
            <span
              class="inline-flex items-center gap-2 rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-medium tracking-wide text-amber-300"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
              Ebook digital + 4 bonos incluidos
            </span>

            <h1
              class="mt-5 text-3xl font-semibold tracking-tight text-stone-50 sm:text-4xl lg:text-[2.75rem] lg:leading-[1.1]"
            >
              {product.title}
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-relaxed text-stone-300">
              {product.subtitle}
            </p>

            <!-- Price block -->
            <div class="mt-8 flex flex-wrap items-end gap-x-4 gap-y-2">
              {
                product.regularPriceCLP && (
                  <span class="text-lg text-stone-400 line-through">
                    {formatCLP(product.regularPriceCLP)}
                  </span>
                )
              }
              <span class="text-4xl font-bold text-stone-50">
                {formatCLP(product.priceCLP)}
              </span>
              {
                discountPct > 0 && (
                  <span class="rounded-md bg-emerald-500/15 px-2 py-1 text-sm font-semibold text-emerald-400">
                    -{discountPct}% precio de lanzamiento
                  </span>
                )
              }
            </div>

            <p class="mt-4 max-w-md text-sm font-medium text-stone-300">
              Incluye ebook PDF + EPUB + Kindle/AZW3 + 4 hojas de referencia
              imprimibles.
            </p>

            <!-- Buy form -->
            <form
              method="POST"
              action="/api/checkout/flow"
              class="mt-6 max-w-md"
            >
              <input type="hidden" name="slug" value={product.slug} />
              <div class="flex flex-col gap-3 sm:flex-row">
                <input
                  type="email"
                  name="email"
                  required
                  placeholder="tucorreo@ejemplo.com"
                  class="w-full flex-1 rounded-lg border border-stone-700 bg-stone-950/80 px-4 py-3 text-stone-100 placeholder:text-stone-600 focus:border-amber-400 focus:ring-1 focus:ring-amber-400 focus:outline-none"
                />
                <button
                  type="submit"
                  class="rounded-lg bg-amber-400 px-6 py-3 font-semibold text-stone-950 transition hover:bg-amber-300"
                >
                  Comprar ahora
                </button>
              </div>
              <p class="mt-3 text-sm text-stone-400">
                Descarga por correo después del pago · Pago seguro en Chile vía Flow.
              </p>
            </form>

            <p
              class="mt-5 max-w-md rounded-lg border border-stone-700 bg-stone-900/60 px-4 py-3 text-sm leading-relaxed text-stone-300"
            >
              No es una sala de señales. No incluye alertas. No promete ganancias.
              Es una guía práctica para construir proceso, riesgo y disciplina.
            </p>
          </div>

          <!-- Hero cover -->
          <div class="mx-auto w-full max-w-xs lg:max-w-none">
            <div class="relative">
              <div
                class="absolute -inset-4 rounded-2xl bg-amber-400/10 blur-2xl"
                aria-hidden="true"
              >
              </div>
              <img
                src={product.coverImage}
                alt={`Portada de ${product.title}`}
                class="relative aspect-[2/3] w-full rounded-xl border border-stone-700/60 object-cover shadow-2xl shadow-black/50"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────── LO QUE RECIBES HOY ───────────── -->
    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-semibold text-stone-50 sm:text-3xl">
          Lo que recibes hoy
        </h2>
        <p class="mt-3 text-stone-300">
          No es solo el libro: es el paquete completo para llevar lo que lees a tu operativa.
        </p>
      </div>

      <ul
        class="mx-auto mt-10 grid max-w-3xl gap-3 sm:grid-cols-2"
      >
        {
          product.included.map((item) => (
            <li class="flex items-start gap-3 rounded-xl border border-stone-700 bg-stone-900/60 px-4 py-3.5">
              <svg
                class="mt-0.5 h-5 w-5 flex-none text-emerald-400"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0z"
                  clip-rule="evenodd"
                />
              </svg>
              <span class="text-stone-200">
                {item.label}
                {item.note && (
                  <span class="block text-sm text-stone-400">{item.note}</span>
                )}
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <!-- ───────────── POR QUÉ ESTE LIBRO EXISTE ───────────── -->
    <section class="border-y border-stone-800/80 bg-stone-900/50">
      <div class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
        <p class="text-sm font-medium tracking-widest text-amber-400 uppercase">
          Por qué este libro existe
        </p>
        <h2 class="mt-3 text-2xl font-semibold text-stone-50 sm:text-3xl">
          Puedes ganar la mayoría de tus trades y aun así perder dinero.
        </h2>
        <div class="mt-6 space-y-5 text-lg leading-relaxed text-stone-300">
          <p>
            La mayoría de los traders creen que su problema son las entradas. Buscan
            el setup perfecto, otra estrategia, otra sala de señales. Pero el verdadero
            agujero suele estar en otro lado.
          </p>
          <p>
            Puedes acertar en el 70% de tus operaciones y terminar el mes en rojo,
            porque <strong class="text-stone-100">unas pocas pérdidas sin control
            borran semanas de ganancias.</strong> No es el mercado: es la falta de un
            sistema que proteja tu cuenta cuando las cosas se ponen feas.
          </p>
          <p>
            Este libro existe para mostrarte dónde se fuga realmente tu capital y cómo
            empezar a construir un proceso —reglas de riesgo, journaling y revisión—
            que mantenga tus malos días pequeños.
          </p>
        </div>
      </div>
    </section>

    <!-- ───────────── STAT / CHART CARD ───────────── -->
    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-semibold text-stone-50 sm:text-3xl">
          El problema, en números
        </h2>
        <p class="mt-3 text-stone-300">
          Un ejemplo ilustrativo de cómo un buen porcentaje de aciertos puede esconder
          una cuenta que pierde.
        </p>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <!-- Win rate -->
        <div
          class="rounded-2xl border border-stone-700 bg-stone-900/70 p-6 text-center"
        >
          <p class="text-5xl font-bold text-emerald-400">73%</p>
          <p class="mt-2 font-medium text-stone-200">de trades ganadores</p>
          <p class="mt-1 text-sm text-stone-400">
            Un porcentaje de aciertos que casi cualquiera firmaría.
          </p>
        </div>

        <!-- Result -->
        <div
          class="rounded-2xl border border-red-500/30 bg-red-500/[0.06] p-6 text-center"
        >
          <p class="text-5xl font-bold text-red-400">−$</p>
          <p class="mt-2 font-medium text-stone-200">y aun así perdiendo dinero</p>
          <p class="mt-1 text-sm text-stone-400">
            Porque el tamaño de las pérdidas pesa más que la frecuencia de los aciertos.
          </p>
        </div>

        <!-- 5 trades -->
        <div
          class="rounded-2xl border border-stone-700 bg-stone-900/70 p-6 text-center"
        >
          <p class="text-5xl font-bold text-amber-400">5</p>
          <p class="mt-2 font-medium text-stone-200">trades causaron casi todo el daño</p>
          <p class="mt-1 text-sm text-stone-400">
            Identificarlos y controlarlos cambia toda la curva de capital.
          </p>
        </div>
      </div>

      <!-- Mini bar comparison -->
      <div
        class="mx-auto mt-6 max-w-2xl rounded-2xl border border-stone-700 bg-stone-900/70 p-6"
      >
        <div class="space-y-4">
          <div>
            <div class="mb-1 flex justify-between text-sm">
              <span class="text-stone-300">Ganancia de los trades ganadores</span>
              <span class="text-emerald-400">+</span>
            </div>
            <div class="h-3 w-full rounded-full bg-stone-800">
              <div class="h-3 w-[55%] rounded-full bg-emerald-500/70"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex justify-between text-sm">
              <span class="text-stone-300">Pérdida de unos pocos trades sin control</span>
              <span class="text-red-400">−</span>
            </div>
            <div class="h-3 w-full rounded-full bg-stone-800">
              <div class="h-3 w-[78%] rounded-full bg-red-500/70"></div>
            </div>
          </div>
        </div>
        <p class="mt-4 text-center text-xs text-stone-400">
          Ejemplo ilustrativo. No representa resultados reales ni garantizados.
        </p>
      </div>
    </section>

    <!-- ───────────── BONOS INCLUIDOS ───────────── -->
    <section class="border-y border-stone-800/80 bg-stone-900/50">
      <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <span
            class="inline-flex rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-medium tracking-wide text-amber-300"
          >
            Incluido sin costo extra
          </span>
          <h2 class="mt-4 text-2xl font-semibold text-stone-50 sm:text-3xl">
            4 bonos prácticos para usar mientras operas
          </h2>
          <p class="mt-3 text-stone-300">
            Hojas de referencia diseñadas para tomar decisiones más rápido y con reglas claras.
          </p>
        </div>

        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {
            product.bonuses.map((bonus, i) => (
              <div class="group flex flex-col overflow-hidden rounded-2xl border border-stone-700 bg-stone-900/60 transition hover:border-amber-400/40">
                {/* Image area — drop /public/images/bonus-{n}.png to replace the placeholder. */}
                <div class="relative aspect-[4/3] overflow-hidden border-b border-stone-800 bg-gradient-to-br from-stone-800 to-stone-950">
                  <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-amber-300/70">
                    <svg
                      class="h-9 w-9"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      aria-hidden="true"
                    >
                      <rect x="3" y="4" width="18" height="16" rx="2" />
                      <path d="M3 15l5-4 4 3 4-5 5 6" />
                    </svg>
                    <span class="text-[11px] font-medium tracking-wider uppercase">
                      Vista previa
                    </span>
                  </div>
                  <img
                    src={`/images/bonus-${i + 1}.png`}
                    alt={`Vista previa: ${bonus.title}`}
                    loading="lazy"
                    class="relative h-full w-full object-cover transition group-hover:scale-[1.02]"
                    onerror="this.style.display='none'"
                  />
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <div class="flex items-center gap-3">
                    <span class="flex h-8 w-8 flex-none items-center justify-center rounded-lg bg-amber-400/15 text-sm font-bold text-amber-300">
                      {i + 1}
                    </span>
                    <span class="text-xs font-medium tracking-wider text-stone-400 uppercase">
                      Bono {i + 1}
                    </span>
                  </div>
                  <h3 class="mt-4 font-semibold text-stone-100">{bonus.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-stone-300">
                    {bonus.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────── PARA QUIÉN ES / NO ES ───────────── -->
    <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-emerald-500/25 bg-emerald-500/[0.05] p-7">
          <h3 class="text-xl font-semibold text-stone-50">Para quién es</h3>
          <ul class="mt-5 space-y-3 text-stone-300">
            {
              [
                'Traders que tienen buenas entradas pero malos resultados.',
                'Quienes ganan muchos trades y aun así no ven crecer su cuenta.',
                'Operadores de small caps que quieren reglas de riesgo claras.',
                'Quienes están listos para revisar su proceso con honestidad.'
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 text-emerald-400">✓</span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="rounded-2xl border border-red-500/25 bg-red-500/[0.05] p-7">
          <h3 class="text-xl font-semibold text-stone-50">Para quién NO es</h3>
          <ul class="mt-5 space-y-3 text-stone-300">
            {
              [
                'Quien busca hacerse rico rápido o ganancias garantizadas.',
                'Quien quiere señales o alertas para copiar sin entender.',
                'Quien no está dispuesto a revisar sus propios trades.',
                'Quien espera un atajo en lugar de un proceso.'
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 text-red-400">✕</span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- ───────────── QUÉ CUBRE EL LIBRO ───────────── -->
    <section class="border-y border-stone-800/80 bg-stone-900/50">
      <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
        <div class="grid gap-10 lg:grid-cols-[20rem_minmax(0,1fr)]">
          <div>
            <h2 class="text-2xl font-semibold text-stone-50 sm:text-3xl">
              Qué cubre el libro
            </h2>
            <p class="mt-3 text-stone-300">
              De los fundamentos a la psicología, en un recorrido estructurado.
            </p>
            <div class="mt-6 flex gap-6">
              <div>
                <p class="text-3xl font-bold text-amber-400">{product.details.pages}</p>
                <p class="text-sm text-stone-400">páginas</p>
              </div>
              <div>
                <p class="text-3xl font-bold text-amber-400">{product.details.chapters}</p>
                <p class="text-sm text-stone-400">capítulos</p>
              </div>
              <div>
                <p class="text-3xl font-bold text-amber-400">{product.details.parts}</p>
                <p class="text-sm text-stone-400">partes</p>
              </div>
            </div>
          </div>

          <ul class="grid gap-3 sm:grid-cols-2">
            {
              product.coverage.map((topic) => (
                <li class="flex items-start gap-3 rounded-xl border border-stone-700 bg-stone-900/60 px-4 py-3.5 text-stone-200">
                  <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-amber-400" aria-hidden="true" />
                  <span>{topic}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <!-- ───────────── VISTA PREVIA DEL LIBRO ───────────── -->
    <section class="border-y border-stone-800/80 bg-stone-900/50">
      <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
        <div class="mx-auto max-w-2xl text-center">
          <p class="text-sm font-medium tracking-widest text-amber-400 uppercase">
            Vista previa del libro
          </p>
          <h2 class="mt-3 text-2xl font-semibold text-stone-50 sm:text-3xl">
            Un vistazo a lo que vas a leer
          </h2>
          <p class="mt-3 text-stone-300">
            Tres pasajes que muestran el tono: directo, honesto y escrito desde dentro
            del problema.
          </p>
        </div>

        <div class="mt-10 grid gap-5 md:grid-cols-3">
          {
            previews.map((preview, i) => (
              <article class="flex flex-col rounded-2xl border border-stone-700 bg-stone-900/60 p-6">
                <span class="text-sm font-semibold tracking-widest text-amber-300">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="mt-3 text-lg font-semibold text-stone-100">
                  {preview.title}
                </h3>
                <p class="mt-3 flex-1 leading-relaxed text-stone-300">
                  “{preview.teaser}”
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────── FAQ ───────────── -->
    <section class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
      <h2 class="text-center text-2xl font-semibold text-stone-50 sm:text-3xl">
        Preguntas frecuentes
      </h2>
      <div class="mt-10 space-y-3">
        {
          faqs.map((faq) => (
            <details class="group rounded-xl border border-stone-700 bg-stone-900/60 px-5 py-4">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-stone-100">
                {faq.q}
                <span class="text-stone-400 transition group-open:rotate-45">+</span>
              </summary>
              <p class="mt-3 text-stone-300">{faq.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <!-- ───────────── FINAL CTA ───────────── -->
    <section class="border-t border-stone-800/80 bg-stone-900/50">
      <div class="mx-auto max-w-2xl px-6 py-16 text-center sm:py-20">
        <h2 class="text-2xl font-semibold text-stone-50 sm:text-3xl">
          Empieza a construir un proceso que proteja tu cuenta
        </h2>
        <div class="mt-6 flex flex-wrap items-end justify-center gap-x-4 gap-y-2">
          {
            product.regularPriceCLP && (
              <span class="text-lg text-stone-400 line-through">
                {formatCLP(product.regularPriceCLP)}
              </span>
            )
          }
          <span class="text-4xl font-bold text-stone-50">
            {formatCLP(product.priceCLP)}
          </span>
        </div>

        <form
          method="POST"
          action="/api/checkout/flow"
          class="mx-auto mt-6 max-w-md"
        >
          <input type="hidden" name="slug" value={product.slug} />
          <div class="flex flex-col gap-3 sm:flex-row">
            <input
              type="email"
              name="email"
              required
              placeholder="tucorreo@ejemplo.com"
              class="w-full flex-1 rounded-lg border border-stone-700 bg-stone-950/80 px-4 py-3 text-stone-100 placeholder:text-stone-600 focus:border-amber-400 focus:ring-1 focus:ring-amber-400 focus:outline-none"
            />
            <button
              type="submit"
              class="rounded-lg bg-amber-400 px-6 py-3 font-semibold text-stone-950 transition hover:bg-amber-300"
            >
              Comprar ahora
            </button>
          </div>
        </form>
        <p class="mt-4 text-sm text-stone-400">
          Recibes un correo con los botones de descarga después del pago.
        </p>
        <p class="mx-auto mt-6 max-w-md text-xs leading-relaxed text-stone-600">
          Solo para fines educativos. No es asesoramiento financiero. No incluye
          alertas ni señales. El trading conlleva riesgo de pérdida de capital.
        </p>
      </div>
    </section>
  </article>

  <!-- ───────────── STICKY MOBILE BUY BAR ───────────── -->
  <div
    class="fixed inset-x-0 bottom-0 z-40 border-t border-stone-800 bg-stone-950/95 backdrop-blur lg:hidden"
  >
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
      <div class="leading-tight">
        <div class="flex items-baseline gap-2">
          {
            product.regularPriceCLP && (
              <span class="text-xs text-stone-400 line-through">
                {formatCLP(product.regularPriceCLP)}
              </span>
            )
          }
          <span class="text-lg font-bold text-stone-50">
            {formatCLP(product.priceCLP)}
          </span>
        </div>
        <span class="text-[11px] text-stone-400">Ebook + 4 bonos</span>
      </div>
      <a
        href={buyHref}
        class="rounded-lg bg-amber-400 px-5 py-2.5 text-sm font-semibold text-stone-950 transition hover:bg-amber-300"
      >
        Comprar ahora
      </a>
    </div>
  </div>
</BaseLayout>
